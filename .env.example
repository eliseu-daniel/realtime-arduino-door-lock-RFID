# === Servidor ===
PORT=3000

# === Banco de Dados MySQL ===
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=controle_acesso

# === JWT ===
JWT_SECRET=seu_secret_aqui
JWT_EXPIRES_IN=7d

# === Arduino Serial ===
SERIAL_PORT=/dev/ttyUSB0
SERIAL_BAUD_RATE=9600

